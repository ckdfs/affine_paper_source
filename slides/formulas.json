    {
      "id": "mzm",
      "latex": "P_{\\mathrm{out}}(t)=\\tfrac{P_0}{2}\\bigl[1+\\eta\\cos\\varphi(t)\\bigr],\\quad \\eta=\\tfrac{2\\sqrt{r}}{1+r}\\le 1",
