    },
    {
      "id": "lockin",
      "latex": "\\mathcal{L}_1[f]=\\overline{2f(t)\\sin(\\omega t+\\theta_1)},\\quad \\mathcal{L}_2[f]=\\overline{2f(t)\\cos(2\\omega t+\\theta_2)}",
      "mode": "display"
    },
    {
      "id": "ideal",
