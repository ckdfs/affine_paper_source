        <mxCell id="e7" value="推广 S¹→T³" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeColor=#d6822b;strokeWidth=2.5;fontSize=11;fontColor=#b35d00;fontStyle=1;" edge="1" parent="1" source="a2" target="b1"><mxGeometry relative="1" as="geometry" /></mxCell>
