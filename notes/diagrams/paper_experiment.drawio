        <mxCell id="note_freq" value="频率：三音 1:1.37:1.93 于 PP-10G 通带；m≈0.13 → κ(A)≈30，FFT 平均换 SNR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef7ec;strokeColor=#3aa18c;fontSize=12;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="424" y="350" width="200" height="68" as="geometry" /></mxCell>
