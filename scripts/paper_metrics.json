{
  "_doc": "Number contract for paper_zh.tex. Each entry is one headline figure that appears in the manuscript (mostly Table tab:results). check.py verifies BOTH directions: (1) `tex` literal must occur in paper_zh.tex (catches a hand-edited / stale table cell); (2) `sim` regex must match the captured simulation stdout and the parsed value must be within `tol` of `expect` (catches the script drifting away from the paper). When a number legitimately changes: rerun `build.py figs`, read build/sim_output.txt, update `expect` here and the `tex` literal in paper_zh.tex, then `check.py` must pass. Group prefix maps to the printing script: Fig4/cal/obs/Fig7/MC/V -> make_figs.py; gauge/mcdp/sweep -> make_extra_figs.py; acq/step/recal -> make_algo_figs.py.",
  "tolerance_note": "tol is absolute in the value's own unit unless rel=true (then fractional).",
  "metrics": [
    {"name": "MZM closed-loop affine rms @phi*=1.9", "tex": "仿射~$12.7$",
     "sim": "\\[Fig4\\][^\\n]*affine RMS=([0-9.]+)", "expect": 12.7, "tol": 0.5},
    {"name": "MZM closed-loop H1 amplitude-match rms", "tex": "H1 匹配~$1315$",
     "sim": "\\[Fig4\\][^\\n]*H1 RMS=([0-9.]+)", "expect": 1315, "tol": 5},
    {"name": "MZM noisy-cal demod bias median", "tex": "中位~$2.35$",
     "sim": "\\[MC\\][^\\n]*median=([0-9.]+)", "expect": 2.35, "tol": 0.3},
    {"name": "MZM noisy-cal demod bias P95", "tex": "P95~$6.25$",
     "sim": "\\[MC\\][^\\n]*P95=([0-9.]+)", "expect": 6.25, "tol": 0.5},
    {"name": "MZM kappa(A) perturbed-true", "tex": "$2.59$（理想比值~$3.13$）",
     "sim": "\\[V\\] MZM kappa\\(A\\) true=([0-9.]+)", "expect": 2.59, "tol": 0.05},
    {"name": "MZM zero-noise demod error (machine precision)", "tex": "$0.0000$~mrad（数值精度）",
     "sim": "\\[V\\] MZM zero-noise demod error: max=([0-9.eE+-]+)", "expect": 0.0, "tol": 1e-9},
    {"name": "MZM zero-noise A_hat vs A Frobenius", "tex": "Frobenius 误差~$0.00\\%$",
     "sim": "\\[V\\] MZM zero-noise A_hat vs A Frobenius rel error: ([0-9.eE+-]+)", "expect": 0.0, "tol": 1e-6},
    {"name": "gauge regression vs argmin median", "tex": "${\\sim}2$ 对~${\\sim}42$~mrad",
     "sim": "\\[gauge\\] N=360: regression median=([0-9.]+)", "expect": 2.0, "tol": 1.5},
    {"name": "DPMZM noisy identification relF", "tex": "$0.17\\%$",
     "sim": "\\[cal\\] DPMZM identification relF=([0-9.eE+-]+)", "expect": 0.1686, "tol": 0.02},
    {"name": "DPMZM noisy-cal demod bias median", "tex": "中位~$2.1$、P95~$4.3$~mrad",
     "sim": "\\[V\\] DPMZM noisy-cal demod bias: median=([0-9.]+)", "expect": 2.1, "tol": 0.5},
    {"name": "DPMZM dfeat finite-difference", "tex": "最大~$7.7\\times10^{-10}$",
     "sim": "\\[V\\] DPMZM dfeat vs finite-difference: max=([0-9.eE+-]+)", "expect": 7.7e-10, "tol": 5e-10},
    {"name": "DPMZM Klein invariance", "tex": "$2.5\\times10^{-15}$",
     "sim": "\\[V\\] DPMZM Klein invariance[^\\n]*max=([0-9.eE+-]+)", "expect": 2.5e-15, "tol": 5e-15},
    {"name": "DPMZM zero-noise identification relF", "tex": "$2.4\\times10^{-14}\\%$",
     "sim": "\\[V\\] DPMZM zero-noise identification relF=([0-9.eE+-]+)", "expect": 2.4e-14, "tol": 5e-14},
    {"name": "DPMZM exact-model GN recovery", "tex": "$5\\times10^{-13}$~mrad",
     "sim": "exact-model GN recovery max=([0-9.eE+-]+)", "expect": 5e-13, "tol": 5e-13},
    {"name": "obs sigma_min 6ch standard point (machine zero)", "tex": "$\\approx 0$（机器精度）",
     "sim": "6ch@std=([0-9.eE+-]+)", "expect": 0.0, "tol": 1e-15},
    {"name": "obs sigma_min 9ch standard point", "tex": "$5.5\\times10^{-2}$",
     "sim": "9ch@std=([0-9.]+)", "expect": 0.055, "tol": 0.005},
    {"name": "obs sigma_min 9ch at (pi,pi,0)", "tex": "$1.1\\times10^{-17}$",
     "sim": "9ch@\\(pi,pi,0\\)=([0-9.eE+-]+)", "expect": 1.13e-17, "tol": 5e-17},
    {"name": "DPMZM closed-loop GN arbitrary target", "tex": "GN~$17.2$ / 三环~$358$",
     "sim": "arbitrary target[^\\n]*GN RMS=([0-9.]+)", "expect": 17.2, "tol": 1.0},
    {"name": "DPMZM closed-loop GN standard target", "tex": "GN~$18.5$ / 三环~$397$",
